{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import", "unicorn"],
  "jsPlugins": ["./lint-rules/index.mjs"],
  "env": {
    "browser": true,
    "node": true
  },
  "globals": {
    "React": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "eslint/curly": "warn",
    "eslint/no-fallthrough": "warn",
    "eslint/no-promise-executor-return": "warn",
    "eslint/no-throw-literal": "warn",
    "eslint/eqeqeq": "warn",
    "eslint/no-self-compare": "warn",
    "eslint/no-template-curly-in-string": "warn",
    "eslint/no-useless-rename": "warn",
    "eslint/no-var": "warn",
    "eslint/prefer-const": "warn",
    "eslint/arrow-body-style": ["warn", "as-needed"],
    "eslint/no-unneeded-ternary": "warn",
    "eslint/prefer-template": "warn",
    "eslint/prefer-object-has-own": "warn",
    "eslint/no-useless-computed-key": "warn",
    "eslint/no-useless-constructor": "warn",
    "eslint/no-lonely-if": "warn",
    "eslint/yoda": "warn",
    "eslint/default-case-last": "warn",
    "eslint/default-param-last": "warn",
    "eslint/no-array-constructor": "warn",
    "eslint/no-nested-ternary": "warn",
    "eslint/prefer-rest-params": "warn",
    "eslint/prefer-spread": "warn",
    "react/jsx-key": "warn",
    "react/no-children-prop": "warn",
    "react-hooks/rules-of-hooks": "warn",
    "react-hooks/exhaustive-deps": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/consistent-type-imports": ["warn", { "fixStyle": "inline-type-imports" }],
    "typescript/consistent-type-definitions": ["warn", "type"],
    "typescript/no-unnecessary-template-expression": "warn",
    "typescript/array-type": "warn",
    "typescript/consistent-type-assertions": "warn",
    "typescript/consistent-generic-constructors": "warn",
    "typescript/consistent-indexed-object-style": "warn",
    "typescript/no-inferrable-types": "warn",
    "typescript/prefer-function-type": "warn",
    "typescript/prefer-ts-expect-error": "warn",
    "typescript/adjacent-overload-signatures": "warn",
    "typescript/switch-exhaustiveness-check": "warn",
    "typescript/no-floating-promises": "warn",
    "typescript/await-thenable": "warn",
    "typescript/no-for-in-array": "warn",
    "typescript/no-misused-promises": "warn",
    "typescript/restrict-plus-operands": "warn",
    "typescript/no-unnecessary-condition": "warn",
    "typescript/no-unsafe-argument": "warn",
    "typescript/no-unsafe-assignment": "warn",
    "typescript/no-unsafe-member-access": "warn",
    "typescript/prefer-nullish-coalescing": "warn",
    "typescript/prefer-optional-chain": "warn",
    "typescript/strict-boolean-expressions": "warn",
    "typescript/no-unnecessary-type-assertion": "warn",
    "typescript/no-confusing-void-expression": "warn",
    "typescript/prefer-for-of": "warn",
    "typescript/no-unnecessary-type-arguments": "warn",
    "typescript/return-await": "warn",
    "typescript/prefer-includes": "warn",
    "typescript/unbound-method": "off",
    "typescript/restrict-template-expressions": "warn",
    "typescript/require-array-sort-compare": "warn",
    "unicorn/consistent-function-scoping": "warn",
    "unicorn/prefer-array-flat-map": "warn",
    "unicorn/prefer-number-properties": "warn",
    "unicorn/catch-error-name": "warn",
    "unicorn/throw-new-error": "warn",
    "unicorn/error-message": "warn",
    "unicorn/no-useless-undefined": "warn",
    "unicorn/switch-case-braces": "warn",
    "unicorn/prefer-string-replace-all": "warn",
    "unicorn/prefer-string-slice": "warn",
    "unicorn/prefer-array-some": "warn",
    "unicorn/prefer-at": "warn",
    "unicorn/prefer-optional-catch-binding": "warn",
    "unicorn/prefer-regexp-test": "warn",
    "unicorn/prefer-date-now": "warn",
    "unicorn/text-encoding-identifier-case": "warn",
    "unicorn/no-useless-promise-resolve-reject": "warn",
    "unicorn/consistent-existence-index-check": "warn",
    "import/no-self-import": "warn",
    "import/no-duplicates": "warn",
    "import/no-absolute-path": "warn",
    "import/no-namespace": "warn",
    "import/consistent-type-specifier-style": ["warn", "prefer-inline"],
    "local/jsdoc-only-on-declarations": "warn",
    "local/no-abbreviated-names": "warn",
    "local/no-ascii-separators": "warn",
    "local/no-classname-concatenation": "warn",
    "local/no-em-dash": "warn",
    "local/no-text-on-jsdoc-line": "warn"
  },
  "ignorePatterns": ["node_modules", "ios", "android", "build", "dist", ".expo", "lint-rules"],
  "overrides": [
    {
      "files": ["scripts/**/*"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
